  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx","**/*.jsx", ".next/types/**/*.ts", "src/app/services/listen-to-the-world/components/Hero.jsx", "src/app/services/listen-to-the-world/components/FreeRadio.jsx", "src/app/services/components/FAQSection.jsx", "src/app/services/listen-to-the-world/components/Reviews.jsx", "src/app/services/listen-to-the-world/components/WhyTalesRM.jsx", "src/app/services/listen-radio-online/components/IndianRadioByLanguage.jsx", "src/app/services/listen-radio-online/components/IndianRadioByCity.jsx", "src/app/services/listen-radio-online/components/MultiSection.jsx", "src/app/services/listen-radio-online/page.jsx"],
  "exclude": ["node_modules", "vtnweb"]
}
